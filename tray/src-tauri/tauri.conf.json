{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpsConsole",
  "version": "0.0.1",
  "identifier": "com.bluevlad.opsconsole.tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4101",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "OpsConsole",
        "width": 420,
        "height": 600,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://opsconsole.unmong.com http://localhost:9100"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "OpsConsole tray agent",
    "longDescription": "OpsConsole multi-service ops dashboard tray agent — health monitoring, change requests, content quick-edit",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US", "ko-KR"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://opsconsole.unmong.com/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "PASTE_YOUR_TAURI_UPDATER_PUBKEY_HERE"
    }
  }
}
