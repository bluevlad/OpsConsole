# OpsConsole — 환경변수 예제
# 실제 값은 .env (gitignore 됨) 또는 docker-compose 환경변수로 주입

# --- App ---
APP_ENV=dev                       # dev / staging / prod
APP_DEBUG=true
APP_TZ=Asia/Seoul

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9100
BACKEND_CORS_ORIGINS=http://localhost:4100,https://opsconsole.unmong.com

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:9100
VITE_GOOGLE_CLIENT_ID=             # Google Identity Services 버튼 — 백엔드 GOOGLE_OAUTH_CLIENT_ID 와 동일

# --- Database (PostgreSQL 공유 컨테이너 — database-services/docker-compose) ---
# 컨테이너 내에서 실행 시: host=postgresql (database-network 내부)
# 로컬에서 실행 시:    host=localhost (5432 포트가 호스트에 노출됨)
DATABASE_URL=postgresql+asyncpg://opsconsole_svc:CHANGE_ME@localhost:5432/opsconsole_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Google OAuth (ID Token flow — CLIENT_SECRET 불필요) ---
# AllergyInsight와 동일 OAuth Client 재사용 (사용자 신원만 공유, JWT/role은 OpsConsole 자체 관리)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4100/auth/callback

# --- GitHub (P0: 매니페스트 fetch / P2: Issue·PR Bridge) ---
GITHUB_PAT=                       # repo:read + issues:write 권한 PAT
GITHUB_API_BASE=https://api.github.com
GITHUB_WEBHOOK_SECRET=             # P2 webhook HMAC-SHA256 검증 (각 레포 webhook 설정과 일치)

# --- Internal content (P3) — 본 서비스가 published 콘텐츠를 polling 할 때 사용 ---
OPS_INTERNAL_TOKEN=                 # 본 서비스 ↔ OpsConsole 공유 비밀 (본 서비스의 .env에도 동일 값)

# --- Slack (P1) ---
SLACK_WEBHOOK_URL=

# --- Manifest sync ---
MANIFEST_DEFAULT_REF=main         # AllergyInsight 매니페스트를 어떤 ref에서 읽을지
MANIFEST_LOCAL_FALLBACK_PATH=     # 비어있으면 GitHub raw 사용. 개발 시 로컬 경로 가능
